# Server för den statiska kartappen
PORT=5173

# Byggläge: vilken region som ska byggas.
# Tillåtna värden: stockholm, vastra-gotaland.
REGION=stockholm

# Var JSON-filen ska skrivas. Default styrs av REGION:
# - public/data/stockholm-grade9-schools.json
# - public/data/vastra-gotaland-grade9-schools.json
OUT_FILE=

# Begränsa kommuner vid test, t.ex. 0180 eller 0180,0182.
# Default: alla kommuner i vald region.
MUNICIPALITY_CODES=

# Skolverkets Planned educations API
SKOLVERKET_PLANNED_BASE_URL=https://api.skolverket.se/planned-educations

# HTTP-cache för själva byggkommandot. Appen använder inte denna.
CACHE_DIR=.cache
HTTP_CACHE_TTL_MS=604800000          # 7 dagar
FORCE_HTTP_REFRESH=0                 # 1 = ignorera HTTP-cache vid ny byggning

# Snäll men snabbare API-takt för build:data.
API_MIN_DELAY_MS=250                 # minst paus mellan API-anrop
PAGE_SIZE=50
MAX_PAGES_PER_MUNICIPALITY=40
STAT_BATCH_SIZE=100
STAT_BATCH_PAUSE_MS=250
REQUEST_TIMEOUT_MS=30000

# Sätt till 1 för att spara råa statistikresponser för felsökning.
SAVE_RAW_STATISTICS=0

# Sätt till 1 för offline-demo med fixture.
USE_SAMPLE_DATA=0
